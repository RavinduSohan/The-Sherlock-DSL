        flow_type: "gradient"
        density: 0.4
        intensity: 0.6
        color: "#95a5a6"
        animated: true
        direction: "inward"
        size: 250
        
      zigzag_text:
        type: text
        text: "True path = local corrections, not straight line"
        position: [0, -200]
        size: 16
        color: "#ffffff"
        glow: true
        font: "Arial"
        
      convergence_text:
        type: text
        text: "Convergence by cumulative effect of small steps"
        position: [0, 180]
        size: 14
        color: "#2ecc71"
        glow: false
        font: "Arial"
        
  scene_7:
    duration: 8
