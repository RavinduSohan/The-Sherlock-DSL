        form: "vector"
        personality: "sharp"
        size: 45
        color: "#e74c3c"
        glow: true
        energy: 0.8
        animation_pattern: "pulse"
        label: "∇f"
        vector_components: [2, -1]
        show_components: true
        show_magnitude: true
        vector_style: "force"
        component_style: "minimal"
        
      path_dot1:
        type: point
        position: [-100, -40]
        radius: 5
        color: "#2ecc71"
        glow: true
        
      path_dot2:
        type: point
        position: [-70, -30]
        radius: 5
        color: "#2ecc71"
        glow: true
        
      path_dot3:
        type: point
        position: [-40, -15]
        radius: 5
        color: "#2ecc71"
        glow: true
        
      path_dot4:
        type: point
        position: [-10, 0]
        radius: 5
        color: "#2ecc71"
        glow: true
        
      recalculate_text:
        type: text
        text: "Recalculate after each tiny step"
        position: [0, -200]
        size: 16
        color: "#ffffff"
        glow: true
        font: "Arial"
        
  scene_6:
    duration: 8
    description: "Zigzag path - true path via local corrections"
    elements:
      path_line:
        type: line
        from: [-120, 80]
        to: [-90, 60]
        thickness: 3
        dashed: false
        color: "#2ecc71"
        opacity: 0.8
        glow: true
        
      path_line2:
        type: line
        from: [-90, 60]
        to: [-50, 35]
        thickness: 3
        dashed: false
        color: "#2ecc71"
        opacity: 0.8
        glow: true
        
      path_line3:
        type: line
        from: [-50, 35]
        to: [-10, 10]
        thickness: 3
        dashed: false
        color: "#2ecc71"
        opacity: 0.8
        glow: true
        
      path_line4:
        type: line
        from: [-10, 10]
        to: [20, -10]
        thickness: 3
        dashed: false
        color: "#2ecc71"
        opacity: 0.8
        glow: true
        
      vector_field_hint:
