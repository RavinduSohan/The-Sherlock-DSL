        position: [0, -120]
        width: 280
        height: 80
        water_color: "#f39c12"
        wave_intensity: 1.0
        
      calculation_text:
        type: text
        text: "x₁ = -5 + 0.1×10 = -4  |  x₂ = -4 + 0.1×8 = -3.2"
        position: [0, 180]
        size: 13
        color: "#f39c12"
        glow: false
        font: "Arial"
        
      title_text:
        type: text
        text: "Small steps → -4 → -3.2 → -2.56 → ... → 0"
        position: [0, -200]
        size: 16
        color: "#ffffff"
        glow: true
        font: "Arial"
        
  scene_9:
