        form: "point"
        personality: "sharp"
        size: 20
        color: "#e74c3c"
        glow: true
        energy: 0.8
        animation_pattern: "pulse"
        label: "x₀=-5"
        
      step1_vector:
        type: mathematical_entity
        position: [-125, -30]
        form: "vector"
        personality: "sharp"
        size: 40
        color: "#f39c12"
        glow: true
        energy: 0.8
        animation_pattern: "pulse"
        label: "η|∇f|"
        vector_components: [2, 0]
