concept: "Gradient Descent: Small Steps to Optimal Solutions"
emoji: "🏔"
total_duration: 98
background: "#0a0a0a"

subtitles:
  - ""
  - ""
  - ""
  - ""
  - ""
  - ""
  - ""
  - ""
  - ""

phases:
  scene_1:
    duration: 8
    description: "Foggy mountains - where is the lowest valley?"
    elements:
      mountain_emoji:
        type: animated_emoji
        emoji: "🏔"
        position: [0, -40]
        size: 100
        movement: "floating-pen"
        glowing: "pulsing-glow"
        rotation: "none"
        reveal: "zoom-reveal"
        speed: "slow"
        delay: "none"
        color: "#95a5a6"
        
      figure_emoji:
        type: animated_emoji
        emoji: "🚶"
        position: [-80, 50]
        size: 70
        movement: "wobble"
        glowing: "none"
        rotation: "none"
        reveal: "slide-reveal"
        speed: "normal"
        delay: "delay-1"
        color: "#3498db"
        
      fog_emoji:
        type: animated_emoji
        emoji: "🌫"
        position: [80, 30]
        size: 90
        movement: "floating-pen"
        glowing: "flicker"
        rotation: "gentle-rotate"
        reveal: "spiral-reveal"
        speed: "ultra-slow"
        delay: "delay-2"
        color: "#ecf0f1"
        
      question_text:
        type: text
        text: "Where is the lowest valley?"
        position: [0, 200]
        size: 18
        color: "#ffffff"
        glow: true
        font: "Arial"
        
  scene_2:
    duration: 7
    description: "Local slope - gradient as local information"
    elements:
      gradient_vector:
        type: mathematical_entity
        position: [0, 0]
        form: "vector"
        personality: "sharp"
        size: 80
        color: "#e74c3c"
        glow: true
        energy: 0.9
        animation_pattern: "pulse"
        label: "∇f(x)"
        vector_components: [-3, -4]
        show_components: true
        show_magnitude: true
        show_angle: false
        vector_style: "force"
        component_style: "elegant"
        
      contour_circle_1:
        type: circle
        center: [0, 0]
        radius: 60
        fill: false
        color: "#95a5a6"
        glow: false
        opacity: 0.4
        
      contour_circle_2:
        type: circle
        center: [0, 0]
        radius: 100
        fill: false
        color: "#95a5a6"
        glow: false
        opacity: 0.3
        
      local_text:
        type: text
        text: "Slope beneath your feet is all you can see"
        position: [0, -200]
        size: 16
        color: "#ffffff"
        glow: true
        font: "Arial"
        
  scene_3:
    duration: 8
    description: "Core mechanism - steepest ascent to descent"
    elements:
      marble_point:
        type: mathematical_entity
        position: [-80, -50]
        form: "point"
        personality: "elegant"
        size: 30
        color: "#3498db"
        glow: true
        energy: 0.9
        animation_pattern: "pulse"
        label: "xₜ"
        
      gradient_at_marble:
        type: mathematical_entity
        position: [-80, -50]
        form: "vector"
        personality: "sharp"
        size: 70
        color: "#e74c3c"
        glow: true
        energy: 0.85
        animation_pattern: "pulse"
        label: "∇f(xₜ)"
        vector_components: [3, 2]
        show_components: true
        show_magnitude: true
        vector_style: "force"
        component_style: "detailed"
        
      next_point:
        type: mathematical_entity
        position: [-30, -10]
        form: "point"
        personality: "elegant"
        size: 25
        color: "#f39c12"
        glow: true
        energy: 0.8
        animation_pattern: "pulse"
        label: "xₜ₊₁"
        
      formula_text:
        type: text
        text: "xₜ₊₁ = xₜ - η∇f(xₜ)"
        position: [0, -200]
        size: 18
        color: "#ffffff"
        glow: true
        font: "Arial"
        
      step_text:
        type: text
        text: "Marble moves tiny distance proportional to η"
        position: [0, 180]
        size: 14
        color: "#2ecc71"
        glow: false
        font: "Arial"
        
  scene_4:
    duration: 7
    description: "Learning rate η - invisible variable controlling convergence"
    elements:
      step_chart:
        type: water_bar_chart
        data: [2, 3, 4, 5, 15, 25, 40, 55]
        position: [0, 40]
        width: 320
        height: 120
        water_color: "#3498db"
        wave_intensity: 1.0
        
      small_eta_label:
        type: text
        text: "η=0.1"
        position: [-120, -60]
        size: 16
        color: "#2ecc71"
        glow: true
        font: "Arial"
        
      large_eta_label:
        type: text
        text: "η=1.1"
        position: [120, -60]
        size: 16
        color: "#e74c3c"
        glow: true
        font: "Arial"
        
      comparison_text:
        type: text
        text: "Size of step changes convergence completely"
        position: [0, -200]
        size: 16
        color: "#ffffff"
        glow: true
        font: "Arial"
        
      convergence_text:
        type: text
        text: "η=0.1 vs η=1.1 → smooth descent vs oscillation"
        position: [0, 180]
        size: 14
        color: "#f39c12"
        glow: false
        font: "Arial"
        
  scene_5:
    duration: 9
    description: "Blind explorer analogy - local slope guiding incremental moves"
    elements:
      parabola_surface:
        type: bell_curve
        position: [0, 50]
        amplitude: 120
        variance: 4000
        mean: 0
        startX: -150
        endX: 150
        color: "#3498db"
        thickness: 4
        glow: true
        
      marble_current:
        type: mathematical_entity
        position: [-100, -40]
        form: "point"
        personality: "elegant"
        size: 25
        color: "#f39c12"
        glow: true
        energy: 0.9
        animation_pattern: "pulse"
        label: "Current"
        
      gradient_step1:
        type: mathematical_entity
