# Grouping Test - Composite Shapes
concept: "Primitive Groups"
emoji: "👥"
total_duration: 12
background: "#0a0e1a"

subtitles:
  - "👥 Grouping System"
  - "Combine primitives into complex shapes"

phases:
  simple_groups:
    duration: 4
    description: "Simple groups"
    elements:
      title:
        type: primitive
        shape: text[text:"Simple Groups" fontSize:24 fill:#58a6ff at:(0,3.5)]

      # Smiley face using group
      smiley:
        type: primitive_group
        shape: group{at:(-3,0)} [
          circle[r:1.2 fill:#ffcc00],
          circle[r:0.15 fill:#000 at:(-0.4,0.3)],
          circle[r:0.15 fill:#000 at:(0.4,0.3)],
          arc[r:0.6 startAngle:3.14 endAngle:6.28 stroke:#000 strokeWidth:3 at:(0,-0.2)]
        ]

      # House using group
      house:
        type: primitive_group
        shape: group{at:(3,0)} [
          square[w:1.5 fill:#8b4513],
          triangle[size:1.8 fill:#c0392b at:(0,1.3)],
          rectangle[w:0.4 h:0.6 fill:#3498db at:(0,-0.3)],
          square[w:0.3 fill:#f39c12 at:(-0.4,0.3)],
          square[w:0.3 fill:#f39c12 at:(0.4,0.3)]
        ]

  complex_groups:
    duration: 4
    description: "Complex composite shapes"
    elements:
      title:
        type: primitive
        shape: text[text:"Complex Compositions" fontSize:24 fill:#58a6ff at:(0,3.5)]

      # Robot face
      robot:
        type: primitive_group
        shape: group{at:(-3,0)} [
          rectangle[w:2 h:2.2 fill:#34495e],
          circle[r:0.2 fill:#e74c3c at:(-0.5,0.5)],
          circle[r:0.2 fill:#e74c3c at:(0.5,0.5)],
          rectangle[w:0.8 h:0.15 fill:#3498db at:(0,-0.3)],
          rectangle[w:0.15 h:0.4 fill:#95a5a6 at:(-1.2,0.8)],
          circle[r:0.2 fill:#bdc3c7 at:(-1.2,1.3)],
          rectangle[w:0.15 h:0.4 fill:#95a5a6 at:(1.2,0.8)],
          circle[r:0.2 fill:#bdc3c7 at:(1.2,1.3)]
        ]

      # Flower
      flower:
        type: primitive_group
        shape: group{at:(3,0)} [
          circle[r:0.4 fill:#f1c40f at:(0,0)],
          ellipse[w:0.6 h:0.9 fill:#e74c3c at:(0,0.8)],
          ellipse[w:0.6 h:0.9 fill:#e74c3c at:(0.7,0.4)],
          ellipse[w:0.6 h:0.9 fill:#e74c3c at:(0.7,-0.4)],
          ellipse[w:0.6 h:0.9 fill:#e74c3c at:(0,-0.8)],
          ellipse[w:0.6 h:0.9 fill:#e74c3c at:(-0.7,-0.4)],
          ellipse[w:0.6 h:0.9 fill:#e74c3c at:(-0.7,0.4)]
        ]

  nested_groups:
    duration: 4
    description: "Nested groups"
    elements:
      title:
        type: primitive
        shape: text[text:"Nested Groups" fontSize:24 fill:#58a6ff at:(0,3.5)]

      # Car with wheels
      car:
        type: primitive_group
        shape: group{at:(0,0)} [
          rectangle[w:3 h:1 fill:#c0392b at:(0,0)],
          rectangle[w:1.5 h:0.8 fill:#3498db at:(0.3,0.7)],
          circle[r:0.4 fill:#34495e at:(-1,-0.7)],
          circle[r:0.2 fill:#95a5a6 at:(-1,-0.7)],
          circle[r:0.4 fill:#34495e at:(1,-0.7)],
          circle[r:0.2 fill:#95a5a6 at:(1,-0.7)]
        ]

      caption:
        type: primitive
        shape: text[text:"All built with primitives!" fontSize:18 fill:#2ecc71 at:(0,-2.8)]
