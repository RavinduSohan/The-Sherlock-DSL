  equation_coordinates:
    duration: 20
    description: "Demonstrate equation coordinate system where [0,0] is at the top-left"
    elements:
      # Background grid to show the coordinate system
      coordinate_grid:
        type: grid
        position: [0, 0]
        spacing: 50
        color: "#333333"
        opacity: 0.5
        
      # Standard center point marker
      center_point:
        type: circle
        center: [0, 0]
        radius: 10
        color: "#ff6b6b"
        fill: true
        glow: true
        
      # Center label
      center_label:
        type: text
        text: "Object [0,0] CENTER"
        position: [0, -20]
        color: "#ffffff"
        size: 16
        glow: true
        
      # X and Y axes
      x_axis:
        type: line
        from: [-400, 0]
        to: [400, 0]
        color: "#4ecdc4"
        thickness: 2
        
      y_axis:
        type: line
        from: [0, -300]
        to: [0, 300]
        color: "#d4af37"
        thickness: 2
      
      # Phase title
      phase_title:
        type: text
        text: "📊 Equation Coordinate System: [0,0] at TOP-LEFT"
        position: [0, 280]
        color: "#e74c3c"
        size: 22
        glow: true
        
      instruction:
        type: text
        text: "For equations, [0,0] is at the top-left corner of the screen"
        position: [0, -280]
        color: "#ffffff"
        size: 18
        
      # Visual for top-left origin (this is equation coordinate [0,0])
      topleft_marker:
        type: circle
        center: [-400, 300]
        radius: 15
        color: "#e74c3c"
        fill: true
        glow: true
        
      topleft_label:
        type: text
        text: "Equation [0,0]"
        position: [-350, 300]
        color: "#e74c3c"
        size: 16
        glow: true
        
      # Equation coordinates as visual points
