# Coordinate System Visualization
# This demonstrates the different coordinate systems in Sherlock
# Objects: [0,0] is the center of the screen
# Equations: [0,0] is the top-left corner

concept: "Sherlock Coordinate Systems"
emoji: "📐"
total_duration: 50
background: "#121212"

subtitles:
  - "📏 Sherlock Positioning System Demonstration"
  - "🎯 Objects: [0,0] is at the center of the screen"
  - "📊 Equations: [0,0] is at the top-left corner"
  - "🔍 Notice the difference in coordinate systems"
  - "⚡ Use this as a reference for positioning"

phases:
  object_coordinates:
    duration: 30
    description: "Demonstrate object coordinate system where [0,0] is at the center"
    elements:
      # Background grid to show the coordinate system
      coordinate_grid:
        type: grid
        position: [0, 0]
        spacing: 50
        color: "#333333"
        opacity: 0.5
        
      # Center point marker
      center_point:
        type: circle
        center: [0, 0]
        radius: 10
        color: "#ff6b6b"
        fill: true
        glow: true
        
      # Center label
      center_label:
        type: text
        text: "[0,0] CENTER"
        position: [0, -20]
        color: "#ffffff"
        size: 16
        glow: true
        
      # X and Y axes
      x_axis:
        type: line
        from: [-400, 0]
        to: [400, 0]
        color: "#4ecdc4"
        thickness: 2
        
      y_axis:
        type: line
        from: [0, -300]
        to: [0, 300]
        color: "#d4af37"
        thickness: 2
        
      # Axis labels
      x_label:
        type: text
        text: "X-axis"
        position: [350, 20]
        color: "#4ecdc4"
        size: 14
        
      y_label:
        type: text
        text: "Y-axis"
        position: [20, 280]
        color: "#d4af37"
        size: 14
      
      # Quadrant Labels
      q1_label:
        type: text
        text: "Quadrant 1 [+X, +Y]"
        position: [200, 200]
        color: "#ffffff"
        size: 14
        
      q2_label:
        type: text
        text: "Quadrant 2 [-X, +Y]"
        position: [-200, 200]
        color: "#ffffff"
        size: 14
        
      q3_label:
        type: text
        text: "Quadrant 3 [-X, -Y]"
        position: [-200, -200]
        color: "#ffffff"
        size: 14
        
      q4_label:
        type: text
        text: "Quadrant 4 [+X, -Y]"
        position: [200, -200]
        color: "#ffffff"
        size: 14
      
      # Points across the screen with labels
      # Top Row (y=250)
      point_1:
        type: circle
        center: [-350, 250]
        radius: 5
        color: "#ff6b6b"
        fill: true
        
      point_1_label:
        type: text
        text: "[-350,250]"
        position: [-350, 270]
        color: "#ffffff"
        size: 10
        
      point_2:
        type: circle
        center: [-250, 250]
        radius: 5
        color: "#ff6b6b"
