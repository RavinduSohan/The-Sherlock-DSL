equations:
  # Equations for Phase 1 (just a title, no coordinates demo yet)
  - id: "phase1_title"
    latex: "\\text{Standard Object Coordinates}"
    position: "top"
    phase: "object_coordinates"
    animation: "fade-in"
  
  # For Phase 2, only show some example named positions
  - id: "named_position_center"
    latex: "\\text{Named position: center}"
    position: "center"
    phase: "equation_coordinates"
    animation: "fade-in"
    
  - id: "named_position_top"
    latex: "\\text{Named position: top}"
    position: "top"
    phase: "equation_coordinates"
    animation: "fade-in"
    
  - id: "named_position_bottom"
    latex: "\\text{Named position: bottom}"
    position: "bottom"
    phase: "equation_coordinates"
    animation: "fade-in"
