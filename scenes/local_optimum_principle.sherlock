        to: [-150, 80]
        relationship_type: "causation"
        strength: 1.0
        color: "#2ecc71"
        animated: true
        bidirectional: false
      
      hook_primary:
        type: text
        text: "Consequence of zero slope"
        position: [0, 180]
        size: 14
        color: "#ffffff"
        glow: true
        font: "Arial"
      
      hook_secondary:
        type: text
        text: "Local perfection ≠ global success"
        position: [0, 220]
        size: 13
        color: "#95a5a6"
        glow: false
        font: "Arial"
      
      evidence_1:
        type: text
        text: "∀ε > 0: f(x* ± ε) < f(x*)"
        position: [220, 50]
        size: 16
        color: "#C06A6A"
        font: "Courier Prime"
      
      evidence_2:
        type: text
        text: "Local perfection achieved"
        position: [220, -50]
        size: 16
        color: "#9AA0A6"
        font: "Courier Prime"
      
      evidence_3:
        type: text
        text: "No better neighbor exists"
        position: [220, -100]
        size: 16
        color: "#9AA0A6"
        font: "Courier Prime"
  
  scene_10:
