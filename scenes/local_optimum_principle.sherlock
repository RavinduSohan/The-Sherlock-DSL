      evidence_3:
        type: text
        text: "Δ has no positive gradient signal"
        position: [220, -80]
        size: 16
        color: "#C06A6A"
        font: "Courier Prime"
  
  scene_13:
    duration: 6
    description: "Detective octopus contemplating the mystery with stars"
    elements:
      detective_guide:
        type: wisdom_character
        character_type: detective_octopus
        position: [0, 0]
        size: 140
        mood: "mysterious"
        expression: "normal"
        talking: true
        breathing: true
        color_scheme: "cosmic"
        personality: "calm"
        speech_bubble: true
