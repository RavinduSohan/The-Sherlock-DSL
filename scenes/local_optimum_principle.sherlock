        to: [-220, 0]
        relationship_type: "causation"
        strength: 0.8
        color: "#e74c3c"
        animated: true
        bidirectional: false
      
      right_connector:
        type: relationship_connector
        from: [-150, 0]
        to: [-80, 0]
        relationship_type: "causation"
        strength: 0.8
        color: "#e74c3c"
        animated: true
        bidirectional: false
      
      down_connector:
