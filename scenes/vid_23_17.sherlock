        shape: rectangle[w:2.5 h:2.0 fill:#c77aff/0 stroke:#c77aff/0 strokeWidth:1.5 at:(4.2,0.8)] ~> rectangle[w:2.5 h:2.0 fill:#c77aff/0.25 stroke:#c77aff/0.5 strokeWidth:1.5 at:(4.2,0.8)] (0.6s, ease.out, 10.7s) ~> rectangle[w:2.5 h:2.0 fill:#c77aff/0.35 stroke:#c77aff/0.6 strokeWidth:1.5 at:(4.2,0.8)] (0.4s, ease.out, 11.9s)

      disk_lbl:
        type: morph
        shape: text[text:"SSD" fontSize:16 fill:#ffffff/0 at:(4.2,1.75)] ~> text[text:"SSD" fontSize:16 fill:#ffffff/0.8 at:(4.2,1.75)] (0.5s, ease.out, 11.4s)

      disk_inner:
        type: morph
        shape: ellipse[w:1.4 h:1.0 fill:#c77aff/0 stroke:#c77aff/0 strokeWidth:1 at:(4.2,0.7)] ~> ellipse[w:1.4 h:1.0 fill:#c77aff/0.15 stroke:#c77aff/0.4 strokeWidth:1 at:(4.2,0.7)] (0.5s, ease.out, 10.8s)

      transfer_arrow:
        type: morph
        shape: line[from:(2.7,0.8) to:(2.7,0.8) stroke:#4fc3f7/0 strokeWidth:2] ~> line[from:(2.7,0.9) to:(3.45,0.9) stroke:#4fc3f7/0.7 strokeWidth:2] (0.5s, ease.out, 11.5s) ~> line[from:(2.7,0.7) to:(3.45,0.7) stroke:#c77aff/0.7 strokeWidth:2] (0.5s, ease.out, 12.3s)

      save_block:
        type: morph
        shape: rectangle[w:0.25 h:0.25 fill:#4fc3f7/0 stroke:#4fc3f7/0 strokeWidth:1 at:(1.8,0.9)] ~> rectangle[w:0.25 h:0.25 fill:#4fc3f7/0.9 stroke:#4fc3f7/1.0 strokeWidth:1.5 at:(1.8,0.9)] (0.3s, ease.out, 11.4s) ~> rectangle[w:0.25 h:0.25 fill:#4fc3f7/0.9 stroke:#4fc3f7/1.0 strokeWidth:1.5 at:(4.2,0.9)] (0.8s, ease.inOut, 11.6s) ~> rectangle[w:0.25 h:0.25 fill:#c77aff/0.9 stroke:#c77aff/1.0 strokeWidth:1.5 at:(4.2,0.9)] (0.3s, ease.out, 12.5s) ~> rectangle[w:0.25 h:0.25 fill:#c77aff/0.9 stroke:#c77aff/1.0 strokeWidth:1.5 at:(1.8,0.9)] (1.0s, ease.inOut, 13.0s)

      latency_lbl_ram:
        type: morph
        shape: text[text:"RAM: 50 ns" fontSize:14 fill:#4fc3f7/0 at:(1.8,-0.5)] ~> text[text:"RAM: 50 ns" fontSize:14 fill:#4fc3f7/0.8 at:(1.8,-0.5)] (0.4s, ease.out, 13.8s)

      latency_lbl_disk:
        type: morph
        shape: text[text:"Disk: 10,000,000 ns" fontSize:14 fill:#c77aff/0 at:(4.2,-0.5)] ~> text[text:"Disk: 10,000,000 ns" fontSize:14 fill:#c77aff/0.8 at:(4.2,-0.5)] (0.4s, ease.out, 14.3s)

      gap_factor:
        type: morph
        shape: text[text:"200,000x" fontSize:22 fill:#ffd54f/0 at:(3.2,-0.9)] ~> text[text:"200,000x" fontSize:22 fill:#ffd54f/0.9 at:(3.2,-0.9)] (0.5s, ease.out, 15.0s)

      bar_ram:
        type: morph
        shape: rectangle[w:0.1 h:0.18 fill:#4fc3f7/0 stroke:#4fc3f7/0 strokeWidth:1 at:(0.7,-1.4)] ~> rectangle[w:0.1 h:0.18 fill:#4fc3f7/0.7 stroke:#4fc3f7/0.85 strokeWidth:1.5 at:(0.7,-1.4)] (0.3s, ease.out, 14.0s)

      bar_disk:
        type: morph
        shape: rectangle[w:0.1 h:0.18 fill:#c77aff/0 stroke:#c77aff/0 strokeWidth:1 at:(0.75,-1.4)] ~> rectangle[w:5.5 h:0.18 fill:#c77aff/0.5 stroke:#c77aff/0.7 strokeWidth:1.5 at:(3.5,-1.4)] (0.8s, ease.out, 14.5s)

      right_pt1:
        type: morph
        shape: text[text:"disk = ~0.1ms to 10ms" fontSize:16 fill:#ffffff/0 at:(3.3,-2.1)] ~> text[text:"disk = ~0.1ms to 10ms" fontSize:16 fill:#ffffff/0.82 at:(3.3,-2.1)] (0.4s, ease.out, 11.8s)

      right_pt2:
        type: morph
        shape: text[text:"save: ram → disk" fontSize:16 fill:#ffffff/0 at:(3.3,-2.65)] ~> text[text:"save: ram → disk" fontSize:16 fill:#ffffff/0.82 at:(3.3,-2.65)] (0.4s, ease.out, 12.8s)

      right_pt3:
        type: morph
        shape: text[text:"open: disk → ram" fontSize:16 fill:#ffffff/0 at:(3.3,-3.2)] ~> text[text:"open: disk → ram" fontSize:16 fill:#ffffff/0.82 at:(3.3,-3.2)] (0.4s, ease.out, 14.0s)

      cinematic:
        type: morph
        shape: text[text:"VOLATILE" fontSize:64 fill:#ffd54f/0 at:(-3.2,0.5)] ~> text[text:"VOLATILE" fontSize:64 fill:#ffd54f/0.9 at:(-3.2,0.5)] (1.2s, ease.out, 30.0s) ~> text[text:"VOLATILE" fontSize:64 fill:#ffd54f/0.9 at:(-3.2,0.5)] (2.5s, ease.inOut, 31.2s) ~> text[text:"VOLATILE" fontSize:18 fill:#ffd54f/0.3 at:(-3.2,0.5)] (1.5s, ease.inOut, 33.8s)

      lbl_1:
        type: primitive
        shape: text[text:"DRAM" fontSize:13 fill:#ffffff/0.3 at:(-4.5,-3.2)] -> fadeIn(0.6s, 35.2s)

      lbl_2:
        type: primitive
        shape: text[text:"Flash Memory" fontSize:13 fill:#ffffff/0.3 at:(0,-3.2)] -> fadeIn(0.6s, 35.6s)

      lbl_3:
