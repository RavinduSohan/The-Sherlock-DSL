        position: [200, 120]
        size: 18
        color: "#3498db"
        glow: true
        font: "Arial"

  scene_6:
    duration: 7
    description: "Surprise meter analogy with detective character"
    elements:
      title_text:
        type: text
        text: "The Surprise Meter 🐙"
        position: [0, -220]
        size: 20
        color: "#ffffff"
        glow: true
        font: "Arial"
      
      detective_guide:
        type: wisdom_character
        character_type: detective_octopus
        position: [0, 0]
        size: 160
        mood: "surprised"
        expression: "normal"
        talking: true
        breathing: true
        color_scheme: "cosmic"
        personality: "energetic"
        speech_bubble: true
        speech_text: "Entropy measures surprise. Routine: low. Chaos: high."
        background_aura: "glow"

  scene_7:
    duration: 8
