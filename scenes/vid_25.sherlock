        movement: "floating-pen"
        glowing: "pulsing-glow"
        rotation: "none"
        reveal: "zoom-reveal"
        speed: "slow"
        delay: "none"
        color: "#e74c3c"
      
      lightning_emoji:
        type: animated_emoji
        emoji: "⚡"
        position: [0, 0]
        size: 80
        movement: "bounce"
        glowing: "flicker"
        rotation: "gentle-rotate"
        reveal: "slide-reveal"
        speed: "fast"
        delay: "delay-1"
        color: "#f1c40f"
      
      books_emoji:
        type: animated_emoji
        emoji: "📚"
        position: [120, 0]
        size: 75
        movement: "wobble"
        glowing: "matrix-code"
        rotation: "spin-clockwise"
        reveal: "spiral-reveal"
        speed: "normal"
        delay: "delay-2"
        color: "#3498db"
      
      unexpected_text:
        type: text
        text: "The more unexpected"
        position: [-220, 120]
        size: 18
        color: "#e74c3c"
        glow: true
        font: "Arial"
      
      informative_text:
        type: text
        text: "The more informative"
        position: [0, 120]
        size: 18
        color: "#f1c40f"
        glow: true
        font: "Arial"
      
      entropy_text:
        type: text
