concept: "Computer Science Fundamentals — OS, Threads, Memory"
emoji: "⚙️"
total_duration: 114
background: "#080c14"

subtitles:
  - ""

phases:

  scene_04_os_processes:
    duration: 38
    description: "The OS mediates every app-hardware request; processes are isolated — one crash cannot kill another."
    elements:

      scene_tag:
        type: primitive
        shape: text[text:"④ OS & PROCESSES" fontSize:15 fill:#ffffff/0.3 at:(-5.2,4.85)] -> fadeIn(0.6s, 0.2s)

      divider:
        type: primitive
        shape: line[from:(0,3.2) to:(0,-3.2) stroke:#ffffff/0.15 strokeWidth:1] -> fadeIn(0.3s, 0s)

      left_title:
        type: primitive
        shape: text[text:"FACT 07 — THE OS" fontSize:22 fill:#ffffff/0.8 at:(-3.2,3.8)] -> fadeIn(0.5s, 0.5s)

      layer_app:
        type: morph
        shape: rectangle[w:3.0 h:0.7 fill:#c77aff/0.3 stroke:#c77aff/0.5 strokeWidth:1.5 at:(-3.2,1.6)] -> fadeIn(0.5s, 0.3s) ~> rectangle[w:3.0 h:0.7 fill:#4fc3f7/0.4 stroke:#4fc3f7/0.65 strokeWidth:1.5 at:(-3.2,1.6)] (0.4s, ease.out, 4.8s) ~> rectangle[w:3.0 h:0.7 fill:#4fc3f7/0.25 stroke:#4fc3f7/0.45 strokeWidth:1.2 at:(-3.2,1.6)] (0.5s, ease.out, 5.5s)

      lbl_app_layer:
        type: primitive
        shape: text[text:"App" fontSize:14 fill:#ffffff/0.88 at:(-3.2,1.6)] -> fadeIn(0.4s, 0.5s)

      layer_os:
        type: morph
        shape: rectangle[w:3.4 h:0.9 fill:#c77aff/0.3 stroke:#c77aff/0.5 strokeWidth:1.5 at:(-3.2,0.3)] -> fadeIn(0.5s, 0.3s) ~> rectangle[w:3.4 h:0.9 fill:#4fc3f7/0.45 stroke:#4fc3f7/0.75 strokeWidth:2 at:(-3.2,0.3)] (0.4s, ease.out, 2.8s) ~> rectangle[w:3.4 h:0.9 fill:#6bffb8/0.35 stroke:#6bffb8/0.6 strokeWidth:2 at:(-3.2,0.3)] (0.5s, ease.out, 5.2s)

      lbl_os_layer:
        type: primitive
        shape: text[text:"OS Kernel" fontSize:14 fill:#ffffff/0.88 at:(-3.2,0.3)] -> fadeIn(0.4s, 0.5s)

      layer_hw:
        type: morph
        shape: rectangle[w:3.0 h:0.7 fill:#c77aff/0.3 stroke:#c77aff/0.5 strokeWidth:1.5 at:(-3.2,-1.0)] -> fadeIn(0.5s, 0.3s) ~> rectangle[w:3.0 h:0.7 fill:#4fc3f7/0.4 stroke:#4fc3f7/0.65 strokeWidth:1.5 at:(-3.2,-1.0)] (0.4s, ease.out, 3.5s) ~> rectangle[w:3.0 h:0.7 fill:#4fc3f7/0.25 stroke:#4fc3f7/0.45 strokeWidth:1.2 at:(-3.2,-1.0)] (0.5s, ease.out, 4.2s)

      lbl_hw_layer:
        type: primitive
        shape: text[text:"CPU / RAM / Disk" fontSize:13 fill:#ffffff/0.88 at:(-3.2,-1.0)] -> fadeIn(0.4s, 0.5s)

      conn_app_os:
        type: morph
        shape: line[from:(-3.2,1.25) to:(-3.2,1.25) stroke:#ff6b9d/0.7 strokeWidth:2] ~> line[from:(-3.2,1.25) to:(-3.2,0.75) stroke:#ff6b9d/0.7 strokeWidth:2] (0.4s, ease.out, 0.8s) ~> line[from:(-3.2,1.25) to:(-3.2,0.75) stroke:#4fc3f7/0.6 strokeWidth:2] (0.4s, ease.out, 2.5s)

      conn_os_hw:
        type: morph
        shape: line[from:(-3.2,-0.15) to:(-3.2,-0.15) stroke:#4fc3f7/0 strokeWidth:1] ~> line[from:(-3.2,-0.15) to:(-3.2,-0.65) stroke:#4fc3f7/0.6 strokeWidth:2] (0.5s, ease.out, 3.2s)

      packet_req:
        type: morph
        shape: rectangle[w:0.22 h:0.22 fill:#4fc3f7/0.9 stroke:#4fc3f7/1.0 strokeWidth:1.5 at:(-3.2,1.6)] ~> rectangle[w:0.22 h:0.22 fill:#ff6b9d/0.9 stroke:#ff6b9d/1.0 strokeWidth:1.5 at:(-3.2,1.05)] (0.35s, ease.out, 0.8s) ~> rectangle[w:0.22 h:0.22 fill:#4fc3f7/0.9 stroke:#4fc3f7/1.0 strokeWidth:1.5 at:(-3.2,1.05)] (0.3s, ease.out, 1.4s) ~> rectangle[w:0.22 h:0.22 fill:#4fc3f7/0.9 stroke:#4fc3f7/1.0 strokeWidth:1.5 at:(-3.2,0.3)] (0.4s, ease.inOut, 2.5s)

      packet_hw:
        type: morph
        shape: rectangle[w:0.22 h:0.22 fill:#6bffb8/0 stroke:#6bffb8/0 strokeWidth:1 at:(-3.2,0.3)] ~> rectangle[w:0.22 h:0.22 fill:#6bffb8/0.9 stroke:#6bffb8/1.0 strokeWidth:1.5 at:(-3.2,0.3)] (0.25s, ease.out, 3.1s) ~> rectangle[w:0.22 h:0.22 fill:#6bffb8/0.9 stroke:#6bffb8/1.0 strokeWidth:1.5 at:(-3.2,-1.0)] (0.45s, ease.inOut, 3.3s) ~> rectangle[w:0.22 h:0.22 fill:#6bffb8/0.9 stroke:#6bffb8/1.0 strokeWidth:1.5 at:(-3.2,0.3)] (0.45s, ease.inOut, 4.2s) ~> rectangle[w:0.22 h:0.22 fill:#6bffb8/0.9 stroke:#6bffb8/1.0 strokeWidth:1.5 at:(-3.2,1.6)] (0.5s, ease.inOut, 5.0s)


      left_pt1:
        type: primitive
        shape: text[text:"os = app ↔ hardware" fontSize:16 fill:#ffffff/0.82 at:(-4.1,-2.1)] -> fadeIn(0.4s, 1.5s)

      left_pt2:
        type: primitive
        shape: text[text:"syscall: app → os" fontSize:16 fill:#ffffff/0.82 at:(-4.1,-2.65)] -> fadeIn(0.4s, 2.8s)

      left_pt3:
        type: primitive
        shape: text[text:"direct hardware = blocked" fontSize:16 fill:#ffffff/0.82 at:(-4.1,-3.2)] -> fadeIn(0.4s, 4.5s)

      right_title:
        type: morph
        shape: text[text:"FACT 08 — PROCESSES" fontSize:22 fill:#ffffff/0 at:(3.8,3.8)] ~> text[text:"FACT 08 — PROCESSES" fontSize:22 fill:#ffffff/0.8 at:(3.8,3.8)] (0.5s, ease.out, 10.3s)

      proc_a_box:
        type: morph
        shape: rectangle[w:1.8 h:2.0 fill:#c77aff/0 stroke:#c77aff/0 strokeWidth:2 at:(1.8,0.8)] ~> rectangle[w:1.8 h:2.0 fill:#c77aff/0.25 stroke:#ffffff/0.5 strokeWidth:2.5 at:(1.8,0.8)] (0.6s, ease.out, 10.5s) ~> rectangle[w:1.8 h:2.0 fill:#ff6b9d/0.4 stroke:#ff6b9d/0.7 strokeWidth:2.5 at:(1.8,0.8)] (0.5s, ease.out, 14.0s)

      lbl_proc_a:
        type: morph
        shape: text[text:"PID 100" fontSize:13 fill:#ffffff/0 at:(1.8,1.65)] ~> text[text:"PID 100" fontSize:13 fill:#ffffff/0.88 at:(1.8,1.65)] (0.5s, ease.out, 10.8s)

      proc_a_cell1:
        type: morph
        shape: rectangle[w:0.28 h:0.22 fill:#4fc3f7/0 stroke:#4fc3f7/0 strokeWidth:1 at:(1.55,1.2)] ~> rectangle[w:0.28 h:0.22 fill:#4fc3f7/0.5 stroke:#4fc3f7/0.7 strokeWidth:1 at:(1.55,1.2)] (0.4s, ease.out, 11.0s) ~> rectangle[w:0.28 h:0.22 fill:#ff6b9d/0.5 stroke:#ff6b9d/0.7 strokeWidth:1 at:(1.55,1.2)] (0.4s, ease.out, 14.0s)

      proc_a_cell2:
        type: morph
        shape: rectangle[w:0.28 h:0.22 fill:#c77aff/0 stroke:#c77aff/0 strokeWidth:1 at:(1.9,1.2)] ~> rectangle[w:0.28 h:0.22 fill:#c77aff/0.4 stroke:#c77aff/0.6 strokeWidth:1 at:(1.9,1.2)] (0.4s, ease.out, 11.1s) ~> rectangle[w:0.28 h:0.22 fill:#ff6b9d/0.5 stroke:#ff6b9d/0.7 strokeWidth:1 at:(1.9,1.2)] (0.4s, ease.out, 14.1s)

      proc_a_cell3:
        type: morph
        shape: rectangle[w:0.28 h:0.22 fill:#4fc3f7/0 stroke:#4fc3f7/0 strokeWidth:1 at:(1.55,0.85)] ~> rectangle[w:0.28 h:0.22 fill:#4fc3f7/0.5 stroke:#4fc3f7/0.7 strokeWidth:1 at:(1.55,0.85)] (0.4s, ease.out, 11.2s) ~> rectangle[w:0.28 h:0.22 fill:#000000/0.85 stroke:#ff6b9d/0.3 strokeWidth:1 at:(1.55,0.85)] (0.6s, ease.out, 14.5s)

      proc_a_cell4:
        type: morph
        shape: rectangle[w:0.28 h:0.22 fill:#4fc3f7/0 stroke:#4fc3f7/0 strokeWidth:1 at:(1.9,0.85)] ~> rectangle[w:0.28 h:0.22 fill:#4fc3f7/0.5 stroke:#4fc3f7/0.7 strokeWidth:1 at:(1.9,0.85)] (0.4s, ease.out, 11.3s) ~> rectangle[w:0.28 h:0.22 fill:#000000/0.85 stroke:#ff6b9d/0.3 strokeWidth:1 at:(1.9,0.85)] (0.6s, ease.out, 14.6s)

      lbl_crashed:
        type: morph
        shape: text[text:"CRASHED" fontSize:13 fill:#ff6b9d/0 at:(1.8,0.3)] ~> text[text:"CRASHED" fontSize:13 fill:#ff6b9d/0.9 at:(1.8,0.3)] (0.4s, ease.out, 14.8s)

      proc_b_box:
        type: morph
        shape: rectangle[w:1.8 h:2.0 fill:#c77aff/0 stroke:#c77aff/0 strokeWidth:2 at:(4.2,0.8)] ~> rectangle[w:1.8 h:2.0 fill:#c77aff/0.25 stroke:#ffffff/0.5 strokeWidth:2.5 at:(4.2,0.8)] (0.6s, ease.out, 10.7s)

      lbl_proc_b:
        type: morph
        shape: text[text:"PID 200" fontSize:13 fill:#ffffff/0 at:(4.2,1.65)] ~> text[text:"PID 200" fontSize:13 fill:#ffffff/0.88 at:(4.2,1.65)] (0.5s, ease.out, 11.0s)

      proc_b_cell1:
        type: morph
        shape: rectangle[w:0.28 h:0.22 fill:#4fc3f7/0 stroke:#4fc3f7/0 strokeWidth:1 at:(3.95,1.2)] ~> rectangle[w:0.28 h:0.22 fill:#4fc3f7/0.5 stroke:#4fc3f7/0.7 strokeWidth:1 at:(3.95,1.2)] (0.4s, ease.out, 11.2s) ~> rectangle[w:0.28 h:0.22 fill:#4fc3f7/0.65 stroke:#4fc3f7/0.85 strokeWidth:1.2 at:(3.95,1.2)] (0.4s, ease.out, 15.0s)

      proc_b_cell2:
        type: morph
        shape: rectangle[w:0.28 h:0.22 fill:#c77aff/0 stroke:#c77aff/0 strokeWidth:1 at:(4.3,1.2)] ~> rectangle[w:0.28 h:0.22 fill:#c77aff/0.4 stroke:#c77aff/0.6 strokeWidth:1 at:(4.3,1.2)] (0.4s, ease.out, 11.3s) ~> rectangle[w:0.28 h:0.22 fill:#4fc3f7/0.5 stroke:#4fc3f7/0.7 strokeWidth:1 at:(4.3,1.2)] (0.4s, ease.out, 15.2s)

      proc_b_cell3:
        type: morph
        shape: rectangle[w:0.28 h:0.22 fill:#4fc3f7/0 stroke:#4fc3f7/0 strokeWidth:1 at:(3.95,0.85)] ~> rectangle[w:0.28 h:0.22 fill:#4fc3f7/0.5 stroke:#4fc3f7/0.7 strokeWidth:1 at:(3.95,0.85)] (0.4s, ease.out, 11.4s)

      proc_b_cell4:
        type: morph
        shape: rectangle[w:0.28 h:0.22 fill:#4fc3f7/0 stroke:#4fc3f7/0 strokeWidth:1 at:(4.3,0.85)] ~> rectangle[w:0.28 h:0.22 fill:#4fc3f7/0.5 stroke:#4fc3f7/0.7 strokeWidth:1 at:(4.3,0.85)] (0.4s, ease.out, 11.5s)

      illegal_arrow:
        type: morph
        shape: line[from:(2.7,1.0) to:(2.7,1.0) stroke:#ff6b9d/0 strokeWidth:2] ~> line[from:(2.7,1.0) to:(3.1,1.0) stroke:#ff6b9d/0.8 strokeWidth:2] (0.4s, ease.out, 12.3s) ~> line[from:(2.7,1.0) to:(2.7,1.0) stroke:#ff6b9d/0 strokeWidth:2] (0.3s, ease.out, 12.9s)

      boundary_pulse:
        type: morph
        shape: line[from:(3.3,-0.2) to:(3.3,1.8) stroke:#ffffff/0.4 strokeWidth:3] ~> line[from:(3.3,-0.2) to:(3.3,1.8) stroke:#6bffb8/0.9 strokeWidth:3.5] (0.3s, ease.out, 12.7s) ~> line[from:(3.3,-0.2) to:(3.3,1.8) stroke:#ffffff/0.4 strokeWidth:3] (0.5s, ease.out, 13.1s)

      lbl_isolated:
