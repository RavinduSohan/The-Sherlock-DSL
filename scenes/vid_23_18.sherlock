        shape: text[text:"ISOLATED" fontSize:14 fill:#6bffb8/0 at:(3.0,-0.35)] ~> text[text:"ISOLATED" fontSize:14 fill:#6bffb8/0.9 at:(3.0,-0.35)] (0.5s, ease.out, 15.8s)

      right_pt1:
        type: morph
        shape: text[text:"process = running program" fontSize:16 fill:#ffffff/0 at:(3.3,-2.1)] ~> text[text:"process = running program" fontSize:16 fill:#ffffff/0.82 at:(3.3,-2.1)] (0.4s, ease.out, 11.5s)

      right_pt2:
        type: morph
        shape: text[text:"private mem space" fontSize:16 fill:#ffffff/0 at:(3.3,-2.65)] ~> text[text:"private mem space" fontSize:16 fill:#ffffff/0.82 at:(3.3,-2.65)] (0.4s, ease.out, 13.0s)

      right_pt3:
        type: morph
        shape: text[text:"1 crash ≠ all crash" fontSize:16 fill:#ffffff/0 at:(3.3,-3.2)] ~> text[text:"1 crash ≠ all crash" fontSize:16 fill:#ffffff/0.82 at:(3.3,-3.2)] (0.4s, ease.out, 15.0s)

      cinematic:
        type: morph
        shape: text[text:"KERNEL" fontSize:64 fill:#ffd54f/0 at:(-3.2,0.5)] ~> text[text:"KERNEL" fontSize:64 fill:#ffd54f/0.9 at:(-3.2,0.5)] (1.2s, ease.out, 30.0s) ~> text[text:"KERNEL" fontSize:64 fill:#ffd54f/0.9 at:(-3.2,0.5)] (2.5s, ease.inOut, 31.2s) ~> text[text:"KERNEL" fontSize:18 fill:#ffd54f/0.3 at:(-3.2,0.5)] (1.5s, ease.inOut, 33.8s)

      lbl_1:
        type: primitive
        shape: text[text:"System Call" fontSize:13 fill:#ffffff/0.3 at:(-4.5,-3.2)] -> fadeIn(0.6s, 35.2s)

      lbl_2:
        type: primitive
        shape: text[text:"Privilege Ring" fontSize:13 fill:#ffffff/0.3 at:(0,-3.2)] -> fadeIn(0.6s, 35.6s)

      lbl_3:
        type: primitive
        shape: text[text:"Page Table" fontSize:13 fill:#ffffff/0.3 at:(4.5,-3.2)] -> fadeIn(0.6s, 36.0s)

  scene_05_threads_abstraction:
    duration: 38
    description: "Shared memory makes threads fast but enables race corruption; every abstraction layer adds measurable latency."
    elements:

      scene_tag:
        type: primitive
        shape: text[text:"⑤ THREADS & ABSTRACTION COST" fontSize:15 fill:#ffffff/0.3 at:(-5.2,4.85)] -> fadeIn(0.6s, 0.2s)

      divider:
        type: primitive
        shape: line[from:(0,3.2) to:(0,-3.2) stroke:#ffffff/0.15 strokeWidth:1] -> fadeIn(0.3s, 0s)

      left_title:
        type: primitive
        shape: text[text:"FACT 09 — THREADS" fontSize:22 fill:#ffffff/0.8 at:(-3.2,3.8)] -> fadeIn(0.5s, 0.5s)

      process_box:
        type: morph
        shape: rectangle[w:3.5 h:2.8 fill:#c77aff/0.15 stroke:#c77aff/0.4 strokeWidth:1.5 at:(-3.2,0.6)] -> fadeIn(0.5s, 0.3s) ~> rectangle[w:3.5 h:2.8 fill:#ff6b9d/0.2 stroke:#ff6b9d/0.5 strokeWidth:1.5 at:(-3.2,0.6)] (0.5s, ease.out, 5.5s)

      lbl_process:
        type: primitive
        shape: text[text:"Process" fontSize:14 fill:#ffffff/0.88 at:(-3.2,1.85)] -> fadeIn(0.4s, 0.5s)

      thread_t1:
        type: morph
        shape: circle[r:0.28 fill:#4fc3f7/0.35 stroke:#4fc3f7/0.6 strokeWidth:1.5 at:(-4.2,1.4)] -> fadeIn(0.5s, 0.4s) ~> circle[r:0.28 fill:#4fc3f7/0.65 stroke:#4fc3f7/0.9 strokeWidth:2 at:(-4.2,1.4)] (0.35s, ease.out, 0.8s) ~> circle[r:0.28 fill:#4fc3f7/0.35 stroke:#4fc3f7/0.6 strokeWidth:1.5 at:(-4.2,1.4)] (0.5s, ease.out, 1.2s)

      lbl_t1:
        type: primitive
        shape: text[text:"T1" fontSize:11 fill:#ffffff/0.88 at:(-4.2,1.4)] -> fadeIn(0.4s, 0.5s)

      thread_t2:
        type: morph
        shape: circle[r:0.28 fill:#4fc3f7/0.35 stroke:#4fc3f7/0.6 strokeWidth:1.5 at:(-3.2,1.4)] -> fadeIn(0.5s, 0.4s) ~> circle[r:0.28 fill:#4fc3f7/0.65 stroke:#4fc3f7/0.9 strokeWidth:2 at:(-3.2,1.4)] (0.35s, ease.out, 1.0s) ~> circle[r:0.28 fill:#ff6b9d/0.65 stroke:#ff6b9d/0.9 strokeWidth:2 at:(-3.2,1.4)] (0.3s, ease.out, 5.2s)

      lbl_t2:
        type: primitive
        shape: text[text:"T2" fontSize:11 fill:#ffffff/0.88 at:(-3.2,1.4)] -> fadeIn(0.4s, 0.5s)

      thread_t3:
        type: morph
        shape: circle[r:0.28 fill:#4fc3f7/0.35 stroke:#4fc3f7/0.6 strokeWidth:1.5 at:(-2.2,1.4)] -> fadeIn(0.5s, 0.4s) ~> circle[r:0.28 fill:#4fc3f7/0.65 stroke:#4fc3f7/0.9 strokeWidth:2 at:(-2.2,1.4)] (0.35s, ease.out, 1.2s) ~> circle[r:0.28 fill:#4fc3f7/0.35 stroke:#4fc3f7/0.6 strokeWidth:1.5 at:(-2.2,1.4)] (0.5s, ease.out, 1.6s)

      lbl_t3:
        type: primitive
        shape: text[text:"T3" fontSize:11 fill:#ffffff/0.88 at:(-2.2,1.4)] -> fadeIn(0.4s, 0.5s)

      shared_mem_cell1:
        type: morph
        shape: rectangle[w:0.38 h:0.28 fill:#4fc3f7/0.3 stroke:#4fc3f7/0.5 strokeWidth:1 at:(-4.1,0.6)] -> fadeIn(0.5s, 0.6s) ~> rectangle[w:0.38 h:0.28 fill:#4fc3f7/0.6 stroke:#4fc3f7/0.85 strokeWidth:1.5 at:(-4.1,0.6)] (0.25s, ease.out, 2.2s) ~> rectangle[w:0.38 h:0.28 fill:#4fc3f7/0.3 stroke:#4fc3f7/0.5 strokeWidth:1 at:(-4.1,0.6)] (0.4s, ease.out, 2.5s)

      shared_mem_cell2:
        type: morph
        shape: rectangle[w:0.38 h:0.28 fill:#4fc3f7/0.3 stroke:#4fc3f7/0.5 strokeWidth:1 at:(-3.6,0.6)] -> fadeIn(0.5s, 0.7s) ~> rectangle[w:0.38 h:0.28 fill:#4fc3f7/0.6 stroke:#4fc3f7/0.85 strokeWidth:1.5 at:(-3.6,0.6)] (0.25s, ease.out, 2.5s) ~> rectangle[w:0.38 h:0.28 fill:#ff6b9d/0.7 stroke:#ff6b9d/0.9 strokeWidth:1.5 at:(-3.6,0.6)] (0.3s, ease.out, 5.3s)

      shared_mem_cell3:
        type: morph
        shape: rectangle[w:0.38 h:0.28 fill:#4fc3f7/0.3 stroke:#4fc3f7/0.5 strokeWidth:1 at:(-3.1,0.6)] -> fadeIn(0.5s, 0.8s) ~> rectangle[w:0.38 h:0.28 fill:#4fc3f7/0.6 stroke:#4fc3f7/0.85 strokeWidth:1.5 at:(-3.1,0.6)] (0.25s, ease.out, 2.8s) ~> rectangle[w:0.38 h:0.28 fill:#4fc3f7/0.3 stroke:#4fc3f7/0.5 strokeWidth:1 at:(-3.1,0.6)] (0.4s, ease.out, 3.1s)

      shared_mem_cell4:
        type: morph
        shape: rectangle[w:0.38 h:0.28 fill:#4fc3f7/0.3 stroke:#4fc3f7/0.5 strokeWidth:1 at:(-2.6,0.6)] -> fadeIn(0.5s, 0.9s) ~> rectangle[w:0.38 h:0.28 fill:#ff6b9d/0.7 stroke:#ff6b9d/0.9 strokeWidth:1.5 at:(-2.6,0.6)] (0.3s, ease.out, 5.1s)

      counter_display:
        type: morph
        shape: text[text:"Counter: 0" fontSize:14 fill:#4fc3f7/0 at:(-3.2,0.1)] ~> text[text:"Counter: 0" fontSize:14 fill:#4fc3f7/0.8 at:(-3.2,0.1)] (0.4s, ease.out, 0.9s) ~> text[text:"Counter: 3" fontSize:14 fill:#4fc3f7/0.8 at:(-3.2,0.1)] (0.5s, ease.out, 1.5s) ~> text[text:"Counter: 100" fontSize:14 fill:#4fc3f7/0.8 at:(-3.2,0.1)] (0.4s, ease.out, 3.2s) ~> text[text:"Counter: 999" fontSize:14 fill:#ff6b9d/0.9 at:(-3.2,0.1)] (0.3s, ease.out, 5.2s) ~> text[text:"Counter: -50" fontSize:14 fill:#ff6b9d/0.9 at:(-3.2,0.1)] (0.25s, ease.out, 5.55s) ~> text[text:"Counter: 0" fontSize:14 fill:#ff6b9d/0.9 at:(-3.2,0.1)] (0.25s, ease.out, 5.85s)

      race_exclaim:
        type: morph
        shape: text[text:"!" fontSize:22 fill:#ff6b9d/0 at:(-3.6,0.7)] ~> text[text:"!" fontSize:22 fill:#ff6b9d/0.9 at:(-3.6,0.7)] (0.2s, ease.out, 5.4s) ~> text[text:"!" fontSize:22 fill:#ff6b9d/0 at:(-3.6,0.7)] (0.5s, ease.out, 6.5s)

      left_pt1:
        type: primitive
        shape: text[text:"thread = cpu worker" fontSize:16 fill:#ffffff/0.82 at:(-4.1,-2.1)] -> fadeIn(0.4s, 1.5s)

      left_pt2:
        type: primitive
        shape: text[text:"threads → shared mem" fontSize:16 fill:#ffffff/0.82 at:(-4.1,-2.65)] -> fadeIn(0.4s, 3.0s)

      left_pt3:
        type: primitive
        shape: text[text:"shared state + timing = race" fontSize:16 fill:#ffffff/0.82 at:(-4.1,-3.2)] -> fadeIn(0.4s, 5.2s)

