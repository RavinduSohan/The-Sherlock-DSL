concept: "testing ground"
emoji: "🧭"
total_duration: 65
background: "#0a0a0a"

subtitles:
  - ""
  - ""
  - ""
  - ""
  - ""
  - ""
  - ""
  - ""
  - ""

phases:
  scene_1_the_rule:
    duration: 5
    description: "The seductive simplicity of the rule"
    elements:
      function_curve:
        type: primitive
        shape: functionGraph[fn:"(x+6)^2/4 - 2" xStart:-6 xEnd:-2 segments:50 stroke:#6bcbff strokeWidth:2 at:(0,0)] -> fadeIn(2s)
      seeker_circle:
        type: primitive
        shape: circle[r:0.3 fill:#ff6b9d at:(-5.5,-1.9)] -> fadeIn(0.5s, 0.5s) -> moveTo((-4.5,-1.4), 1s, linear, 1s) -> moveTo((-3.5,-0.4), 1s, linear) -> moveTo((-2.5,1.1), 1s, ease.out) -> scale(1.2, 0.2s, 4s) -> scale(1.0, 0.2s)
      ghost_1:
        type: primitive
        shape: circle[r:0.3 fill:#ff6b9d/0.2 at:(-4.5,-1.4)] -> fadeIn(0.1s, 2s) -> fadeOut(2s, 4s)
      ghost_2:
        type: primitive
        shape: circle[r:0.3 fill:#ff6b9d/0.2 at:(-3.5,-0.4)] -> fadeIn(0.1s, 3s) -> fadeOut(2s, 4s)
      guide_arrow_1:
        type: primitive
        shape: rectangle[w:0.4 h:0.05 fill:#6bcbff/0.6 at:(-4.5,-1.5)] -> fadeIn(1s, 1s) -> fadeOut(0.5s, 4s)
      guide_arrow_2:
        type: primitive
        shape: rectangle[w:0.4 h:0.05 fill:#6bcbff/0.6 at:(-3.5,-0.5)] -> fadeIn(1s, 1s) -> fadeOut(0.5s, 4s)
      guide_arrow_3:
        type: primitive
        shape: rectangle[w:0.4 h:0.05 fill:#6bcbff/0.6 at:(-2.5,0.5)] -> fadeIn(1s, 1s) -> fadeOut(0.5s, 4s)
      intro_text:
        type: primitive
        shape: text[text:"Most systems follow one rule:" fontSize:24 fill:#F5F5F5 at:(3.0,3.2)] -> fadeIn(1.5s, 0.5s)
      rule_conclusion:
        type: morph
        shape: text[text:"Simple rule." fontSize:32 fill:#9AA0A6 at:(3.0,-1.5)] ~> text[text:"Inevitable." fontSize:32 fill:#B85C5C at:(3.0,-1.5)] (2.0s, ease.inOut, 2.0s)


  scene_7_eternal_question:
    duration: 5
    description: "The void and the point"
    elements:
      # Schrödinger portrait
      schrodinger_portrait:
        type: image_card
        source: "images/icons/penguin.jpg"
        position: [-210, 10]
        size: 400
        border_width: 4
        border_color: "#d4a373"
        glow: true
        glow_color: "#ff6b6b"
        glow_intensity: 35
        border_radius: 15
        ken_burns: zoom_in
        kb_duration: 10
        kb_scale_start: 1.0
        kb_scale_end: 1.5
        kb_easing: ease-in-out
        fade_in: 1.0
        credit: "The nihilistic Penguin"
        credit_position: bottom-right

      the_seeker_remains:
        type: primitive
        shape: circle[r:0.05 fill:#ffffff/0.3 at:(-6.0,-3.0)] -> fadeIn(0.5s, 8s) -> scale(1.5, 0.5s) -> scale(1.0, 0.5s) -> fadeOut(1s, 10s)
      big_question:
        type: primitive
        shape: text[text:"?" fontSize:100 fill:#7E8A8F at:(3.0,2.0)]
      why_chain:
        type: morph
        shape: text[text:"why?" fontSize:48 fill:#B85C5C/0 at:(4.5,-2.0)] ~> text[text:"But why?" fontSize:48 fill:#B85C5C at:(4.5,-2.0)] (1.0s, linear, 5s) ~> text[text:"∞" fontSize:48 fill:#B85C5C at:(4.5,-2.0)] (1.0s, ease.in, 4s) ~> text[text:"?" fontSize:48 fill:#B85C5C at:(4.5,-2.0)] (1.0s, ease.out, 5s)