        to: [-30, 50]
        thickness: 3
        color: "#f39c12"

      arrow_2:
        type: line
        from: [70, 50]
        to: [110, 50]
        thickness: 3
        color: "#f39c12"

      process_text:
        type: text
        text: "Input Data → Matrix Transformation → Recognized Pattern | [x₁,x₂] → M → [y₁,y₂]"
        position: [0, -180]
        size: 14
        color: "#95a5a6"

      title_text:
        type: text
        text: "Final Transformation"
        position: [0, -220]
        size: 20
        color: "#ffffff"