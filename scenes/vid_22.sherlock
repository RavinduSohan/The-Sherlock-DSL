      axis_y_neg:
        type: morph
        shape: line[from:(-4,0) to:(-4,0) stroke:#4A6FA5/0.7 strokeWidth:2] ~> line[from:(-4,0) to:(-4,-3.4) stroke:#4A6FA5/0.7 strokeWidth:2] (0.5s, ease.out, 5.0s)
      number_5_transform:
        type: morph
        shape: text[text:"5" fontSize:40 fill:#F5F5F5 at:(-5,1)] -> fadeIn(0.8s) -> scale(1.15, 0.4s, ease.in, 1.1s) ~> text[text:"↗" fontSize:40 fill:#ffd93d at:(-5,1)] (1.5s, ease.inOut, 1.5s)
      number_3_transform:
        type: morph
        shape: text[text:"3" fontSize:36 fill:#F5F5F5 at:(-4,-1)] -> fadeIn(0.6s, 1.0s) -> scale(1.12, 0.35s, ease.in, 1.65s) ~> text[text:"→" fontSize:36 fill:#6bcbff at:(-4,-1)] (1.2s, ease.inOut, 2.0s)
      number_7_transform:
        type: morph
        shape: text[text:"7" fontSize:36 fill:#F5F5F5 at:(-2.5,2)] -> fadeIn(0.6s, 1.5s) -> scale(1.12, 0.35s, ease.in, 2.15s) ~> text[text:"↑" fontSize:36 fill:#ffd93d at:(-2.5,2)] (1.2s, ease.inOut, 2.5s)
      number_2_transform:
        type: morph
        shape: text[text:"2" fontSize:36 fill:#F5F5F5 at:(-3,-2)] -> fadeIn(0.6s, 2.0s) -> scale(1.12, 0.35s, ease.in, 2.65s) ~> text[text:"↙" fontSize:36 fill:#ff6b9d at:(-3,-2)] (1.2s, ease.inOut, 3.0s)
      vec5_move:
        type: primitive
        shape: text[text:"↗" fontSize:40 fill:#ffd93d/0.0 at:(-5,1)] -> fadeIn(0s, 3.2s) -> moveTo((-3,2.5), 2.0s, spring, 3.2s)
      vec3_move:
        type: primitive
