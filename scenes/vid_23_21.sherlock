concept: "Computer Science Fundamentals — Latency, Consistency, Observability"
emoji: "📡"
total_duration: 114
background: "#080c14"

subtitles:
  - ""

phases:

  scene_13_latency_lb:
    duration: 38
    description: "Batching throughput kills latency; the load balancer makes server failure invisible to users."
    elements:

      scene_tag:
        type: primitive
        shape: text[text:"⑬ LATENCY & LOAD BALANCER" fontSize:15 fill:#ffffff/0.3 at:(-5.2,4.85)] -> fadeIn(0.6s, 0.2s)

      divider:
        type: primitive
        shape: line[from:(0,3.2) to:(0,-3.2) stroke:#ffffff/0.15 strokeWidth:1] -> fadeIn(0.3s, 0s)

      left_title:
        type: primitive
        shape: text[text:"FACT 25 — LATENCY vs THROUGHPUT" fontSize:13 fill:#ffffff/0.8 at:(-3.2,3.8)] -> fadeIn(0.5s, 0.5s)

      stage1:
        type: morph
        shape: rectangle[w:1.1 h:0.55 fill:#c77aff/0.3 stroke:#c77aff/0.5 strokeWidth:1.5 at:(-5.0,1.2)] -> fadeIn(0.5s, 0.3s) ~> rectangle[w:1.1 h:0.55 fill:#4fc3f7/0.4 stroke:#4fc3f7/0.65 strokeWidth:1.5 at:(-5.0,1.2)] (0.3s, ease.out, 0.9s) ~> rectangle[w:1.1 h:0.55 fill:#c77aff/0.3 stroke:#c77aff/0.5 strokeWidth:1.5 at:(-5.0,1.2)] (0.4s, ease.out, 1.4s)

