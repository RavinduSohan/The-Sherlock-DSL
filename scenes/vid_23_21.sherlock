      cinematic:
        type: morph
        shape: text[text:"OBSERVE" fontSize:64 fill:#ffd54f/0 at:(-3.2,0.5)] ~> text[text:"OBSERVE" fontSize:64 fill:#ffd54f/0.9 at:(-3.2,0.5)] (1.2s, ease.out, 30.0s) ~> text[text:"OBSERVE" fontSize:64 fill:#ffd54f/0.9 at:(-3.2,0.5)] (2.5s, ease.inOut, 31.2s) ~> text[text:"OBSERVE" fontSize:18 fill:#ffd54f/0.3 at:(-3.2,0.5)] (1.5s, ease.inOut, 33.8s)

      lbl_1:
