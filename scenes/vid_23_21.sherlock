        type: primitive
        shape: text[text:"10ms" fontSize:12 fill:#ffffff/0.88 at:(-5.0,1.2)] -> fadeIn(0.4s, 0.4s)

      stage2:
        type: morph
        shape: rectangle[w:1.1 h:0.55 fill:#c77aff/0.3 stroke:#c77aff/0.5 strokeWidth:1.5 at:(-3.2,1.2)] -> fadeIn(0.5s, 0.3s) ~> rectangle[w:1.1 h:0.55 fill:#4fc3f7/0.4 stroke:#4fc3f7/0.65 strokeWidth:1.5 at:(-3.2,1.2)] (0.3s, ease.out, 1.2s) ~> rectangle[w:1.1 h:0.55 fill:#c77aff/0.3 stroke:#c77aff/0.5 strokeWidth:1.5 at:(-3.2,1.2)] (0.4s, ease.out, 1.7s) ~> rectangle[w:1.1 h:0.55 fill:#4fc3f7/0.45 stroke:#4fc3f7/0.7 strokeWidth:1.5 at:(-3.2,1.2)] (0.4s, ease.out, 2.8s) ~> rectangle[w:1.1 h:0.55 fill:#c77aff/0.3 stroke:#c77aff/0.5 strokeWidth:1.5 at:(-3.2,1.2)] (0.4s, ease.out, 3.3s)

