      right_pt1:
        type: morph
        shape: text[text:"no perfect system" fontSize:16 fill:#ffffff/0 at:(3.3,-2.1)] ~> text[text:"no perfect system" fontSize:16 fill:#ffffff/0.82 at:(3.3,-2.1)] (0.4s, ease.out, 12.0s)

      right_pt2:
