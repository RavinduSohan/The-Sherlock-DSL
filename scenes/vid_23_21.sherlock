      stage3:
        type: morph
        shape: rectangle[w:1.1 h:0.55 fill:#c77aff/0.3 stroke:#c77aff/0.5 strokeWidth:1.5 at:(-1.4,1.2)] -> fadeIn(0.5s, 0.3s) ~> rectangle[w:1.1 h:0.55 fill:#4fc3f7/0.4 stroke:#4fc3f7/0.65 strokeWidth:1.5 at:(-1.4,1.2)] (0.3s, ease.out, 1.5s) ~> rectangle[w:1.1 h:0.55 fill:#c77aff/0.3 stroke:#c77aff/0.5 strokeWidth:1.5 at:(-1.4,1.2)] (0.4s, ease.out, 2.0s)

