equations:
  - id: alien_alphabet_definition
    latex: "\\text{Alien Alphabet} = \\{a_1, a_2, a_3, \\dots, a_n\\} \\text{ where } a_1 < a_2 < a_3 < \\dots < a_n"
    position: [400, 150]
    phase: solar_system_introduction
    animation: fade-in
    glow: true
    size: 14

  - id: word_comparison
    latex: "\\text{For words } w_i, w_{i+1}: \\text{ find first } j \\text{ where } w_i[j] \\neq w_{i+1}[j] \\Rightarrow w_i[j] < w_{i+1}[j]"
    position: [500, 400]
    phase: building_cosmic_graph
    animation: slide-in
    glow: true
    size: 12

  - id: graph_definition
    latex: "G = (V, E) \\text{ where } V = \\{\\text{unique characters}\\}, E = \\{(c_i, c_j) \\mid c_i < c_j\\}"
    position: [400, 150]
    phase: constructing_character_graph
    animation: fade-in
    glow: true
    size: 14

  - id: topological_order
    latex: "\\text{Topological Order: } \\text{while } V \\neq \\emptyset \\text{ remove } v \\text{ with } \\text{in-degree}(v) = 0"
    position: [400, 300]
    phase: topological_sorting
    animation: slide-in
    glow: true
    size: 12

  - id: kahns_algorithm
    latex: "S \\leftarrow \\{v \\in V \\mid \\text{in-degree}(v) = 0\\}, \\quad L \\leftarrow [] \\\\ \\text{while } S \\neq \\emptyset \\text{ remove } n \\text{ from } S, \\text{ add to } L, \\text{ update neighbors}"
    position: [400, 450]
    phase: kahns_algorithm
    animation: fade-in
    glow: true
    size: 10

  - id: final_order
    latex: "\\text{Alien Order} = [w, e, r, t, f] \\\\ \\text{where } w < e < r < t < f"
    position: [400, 150]
    phase: final_alien_alphabet
    animation: fade-in
    glow: true
    size: 16

  - id: success_formula
    latex: "\\text{Success} = \\text{TopologicalSort}(\\text{CharacterGraph}(\\text{Dictionary}))"
    position: [400, 300]
    phase: mission_accomplished
    animation: slide-in
    glow: true
    size: 14