        emoji: "✨"
        position: [100, 0]
        size: 65
        movement: floating-pen
        glowing: pulsing-glow
        rotation: gentle-rotate
        reveal: zoom-reveal
        speed: slow
        delay: delay-2
        color: "#ffffff"
        
      # Detective text
      collapse_text:
