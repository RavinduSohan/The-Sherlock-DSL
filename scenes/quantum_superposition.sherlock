        size: 14
        color: "#95a5a6"

  scene_13:
    duration: 7
    description: "Quantum technology applications: computing, cryptography, precision"
    elements:
      # Title
      title_text:
        type: text
        text: "🔬 Quantum Technology Applications"
        position: [0, -220]
        size: 18
        color: "#ffffff"
        glow: true
        
      # Qubit matrix (top)
      qubit_matrix:
