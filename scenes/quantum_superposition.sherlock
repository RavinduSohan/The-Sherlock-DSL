      # Cryptography lock (bottom-left)
      crypto_entity:
        type: mathematical_entity
        position: [-160, -20]
        form: hexagon
        personality: wise
        size: 60
        color: "#e74c3c"
        glow: true
        energy: 0.7
        animation_pattern: pulse
        label: "🔒 Crypto"
        
      # Atomic clock chart (bottom-right)
      precision_chart:
        type: animated_bar_chart
        data: [95, 98, 99]
        position: [160, 80]
        width: 150
        height: 80
        color: "#2ecc71"
        
      # Application labels
      computing_label:
        type: text
        text: "Superposition → Computation"
        position: [0, -50]
        size: 12
        color: "#3498db"
        
      security_label:
        type: text
        text: "Measurement → Security"
        position: [-160, 150]
        size: 11
        color: "#e74c3c"
        
      timing_label:
        type: text
        text: "Precision → Timekeeping"
        position: [160, 150]
        size: 11
        color: "#2ecc71"

  scene_14:
    duration: 8
    description: "Montage: Historical to modern quantum technology progression"
    elements:
      # Title
      title_text:
        type: text
        text: "🏛️ The Cornerstone of Quantum Tech"
        position: [0, -220]
        size: 18
        color: "#ffffff"
        glow: true
        
      # Historical paper (left)
      historical_image:
