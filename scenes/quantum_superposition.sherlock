        movement: wobble
        glowing: pulsing-glow
        rotation: none
        reveal: zoom-reveal
        speed: slow
        delay: none
        color: "#ffffff"
        
      # Lightning bolt
      lightning_emoji:
        type: animated_emoji
        emoji: "⚡"
        position: [0, 0]
        size: 75
        movement: bounce
        glowing: flicker
        rotation: none
        reveal: zoom-reveal
        speed: fast
        delay: delay-1
        color: "#f1c40f"
        
      # Star (collapsed state)
      star_emoji:
