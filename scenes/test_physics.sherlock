# Physics & Advanced Animations
concept: "Physics-Based Animations"
emoji: "⚡"
total_duration: 12
background: "#0a0e1a"

subtitles:
  - "⚡ Physics & Advanced Features"
  - "Spring, bounce, elastic, wiggle"

phases:
  spring_animations:
    duration: 4
    description: "Spring physics"
    elements:
      title:
        type: primitive
        shape: text[text:"Spring Physics" fontSize:28 fill:#58a6ff at:(0,3)]

      spring1:
        type: primitive
        shape: circle[r:0.8 fill:#e74c3c at:(-3,1)] -> spring(stiffness:100 damping:10)

      spring2:
        type: primitive
        shape: square[w:1.5 fill:#3498db at:(0,1)] -> spring(stiffness:150 damping:15)

      spring3:
        type: primitive
        shape: star[points:5 outerRadius:1 fill:#2ecc71 at:(3,1)] -> spring(stiffness:80 damping:8)

  bounce_elastic:
    duration: 4
    description: "Bounce and elastic"
    elements:
      title:
        type: primitive
        shape: text[text:"Bounce & Elastic" fontSize:28 fill:#58a6ff at:(0,3)]

      bounce1:
        type: primitive
        shape: circle[r:0.7 fill:#9b59b6 at:(-3,1)] -> bounce(stiffness:120)

      bounce2:
        type: primitive
        shape: triangle[size:1.4 fill:#e67e22 at:(0,1)] -> bounce(stiffness:100)

      elastic1:
        type: primitive
        shape: star[points:6 outerRadius:0.9 fill:#1abc9c at:(3,1)] -> elastic(stiffness:90 damping:12)

  advanced_combos:
    duration: 4
    description: "Advanced combinations"
    elements:
      title:
        type: primitive
        shape: text[text:"Advanced Combos" fontSize:28 fill:#58a6ff at:(0,3)]

      combo1:
        type: primitive
        shape: circle[r:0.6 fill:#ff6b6b at:(-4,1)] -> scale(1.5) -> rotate(45deg) -> fadeIn(1s)

      combo2:
        type: primitive
        shape: square[w:1 fill:#4ecdc4 at:(-2,1)] -> rotate(30deg) -> scale(1.3) -> bounce(stiffness:100)

      combo3:
        type: primitive
        shape: star[points:8 outerRadius:0.8 fill:#f39c12 at:(0,1)] -> scale(1.4) -> spring(stiffness:110)

      combo4:
        type: primitive
        shape: triangle[size:1.2 fill:#27ae60 at:(2,1)] -> rotate(60deg) -> elastic(stiffness:95)

      combo5:
        type: primitive
        shape: ellipse[w:1.4 h:0.9 fill:#d35400 at:(4,1)] -> scale(1.3) -> rotate(20deg) -> fadeIn(1.2s)

      caption:
        type: primitive
        shape: text[text:"Mix and match for infinite possibilities" fontSize:16 fill:#2ecc71 at:(0,-2.5)]
