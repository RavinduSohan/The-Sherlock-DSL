        x_range: [-5, 5]
        y_range: [-2, 2]
        color: "#1abc9c"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = arctan(x)"
        resolution: 150
      
      title_text:
        type: text
        text: "Hyperbolic & Inverse Trigonometric Functions"
        position: [0, -220]
        size: 18
        color: "#ffffff"
        glow: true
        font: "Arial"
  
  scene_8:
    duration: 8
    description: "Combined and composite functions"
    elements:
      sin_cos_sum:
        type: xy_graph
        position: [-260, -80]
        size: 170
        function: "sin(x) + cos(x)"
        x_range: [-6.28, 6.28]
        y_range: [-2, 2]
        color: "#e74c3c"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = sin(x) + cos(x)"
        resolution: 200
      
      sin_cos_product:
        type: xy_graph
        position: [0, -80]
        size: 170
        function: "sin(x) * cos(x)"
        x_range: [-6.28, 6.28]
        y_range: [-1, 1]
        color: "#3498db"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = sin(x)·cos(x)"
        resolution: 200
      
      exp_sin:
        type: xy_graph
        position: [260, -80]
        size: 170
        function: "exp(x) * sin(x)"
        x_range: [-3, 3]
        y_range: [-20, 20]
        color: "#2ecc71"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = eˣ·sin(x)"
        resolution: 200
      
      damped_sin:
        type: xy_graph
        position: [-260, 120]
        size: 170
        function: "exp(-x) * sin(5*x)"
        x_range: [0, 5]
        y_range: [-1, 1]
        color: "#f39c12"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = e⁻ˣ·sin(5x)"
        resolution: 200
      
      sqrt_sin:
        type: xy_graph
        position: [0, 120]
        size: 170
        function: "sqrt(abs(x)) * sin(x)"
        x_range: [-6.28, 6.28]
        y_range: [-3, 3]
        color: "#9b59b6"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = √|x|·sin(x)"
        resolution: 200
      
      log_abs:
        type: xy_graph
        position: [260, 120]
        size: 170
        function: "log(abs(x))"
        x_range: [-10, 10]
        y_range: [-3, 3]
        color: "#1abc9c"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = ln(|x|)"
        resolution: 200
      
      title_text:
        type: text
        text: "Combined & Composite Functions"
        position: [0, -220]
        size: 18
        color: "#ffffff"
        glow: true
        font: "Arial"
  
  scene_9:
    duration: 8
    description: "Higher degree polynomials and rational functions"
    elements:
      quintic:
        type: xy_graph
        position: [-260, -80]
        size: 170
        function: "x^5"
        x_range: [-1.5, 1.5]
        y_range: [-4, 4]
        color: "#e74c3c"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = x⁵"
        resolution: 150
      
      poly_complex1:
        type: xy_graph
        position: [0, -80]
        size: 170
        function: "x^4 - 2*x^2 + 1"
        x_range: [-2, 2]
        y_range: [0, 5]
        color: "#3498db"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = x⁴ - 2x² + 1"
        resolution: 150
      
      poly_complex2:
        type: xy_graph
        position: [260, -80]
        size: 170
        function: "x^3 - 4*x"
        x_range: [-3, 3]
        y_range: [-6, 6]
        color: "#2ecc71"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = x³ - 4x"
        resolution: 150
      
      rational1:
        type: xy_graph
        position: [-260, 120]
        size: 170
        function: "x / (x^2 + 1)"
        x_range: [-5, 5]
        y_range: [-1, 1]
        color: "#f39c12"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = x/(x² + 1)"
        resolution: 150
      
      rational2:
        type: xy_graph
        position: [0, 120]
        size: 170
        function: "(x^2 - 1) / (x^2 + 1)"
        x_range: [-4, 4]
        y_range: [-2, 2]
        color: "#9b59b6"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = (x² - 1)/(x² + 1)"
        resolution: 150
      
      rational3:
        type: xy_graph
        position: [260, 120]
        size: 170
        function: "1 / (x^2 + 1)"
        x_range: [-4, 4]
        y_range: [0, 1.2]
        color: "#1abc9c"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = 1/(x² + 1)"
        resolution: 150
      
      title_text:
        type: text
        text: "Higher Polynomials & Rational Functions"
        position: [0, -220]
        size: 18
        color: "#ffffff"
        glow: true
        font: "Arial"
  
  scene_10:
    duration: 8
    description: "Oscillating and wave functions"
    elements:
      double_freq:
        type: xy_graph
        position: [-260, -80]
        size: 170
        function: "sin(2*x)"
        x_range: [-6.28, 6.28]
        y_range: [-1.5, 1.5]
        color: "#e74c3c"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = sin(2x)"
        resolution: 200
      
      triple_freq:
        type: xy_graph
        position: [0, -80]
        size: 170
        function: "sin(3*x)"
        x_range: [-6.28, 6.28]
        y_range: [-1.5, 1.5]
        color: "#3498db"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = sin(3x)"
        resolution: 200
      
      phase_shift:
        type: xy_graph
        position: [260, -80]
        size: 170
        function: "sin(x - 1.57)"
        x_range: [-6.28, 6.28]
        y_range: [-1.5, 1.5]
        color: "#2ecc71"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = sin(x - π/2)"
