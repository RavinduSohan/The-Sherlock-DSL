      amplitude_mod:
        type: xy_graph
        position: [-260, 120]
        size: 170
        function: "3 * cos(x)"
        x_range: [-6.28, 6.28]
        y_range: [-4, 4]
        color: "#f39c12"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
