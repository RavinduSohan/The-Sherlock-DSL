concept: "XY Graph Function Catalog"
emoji: "📈"
total_duration: 96
background: "#0a0a0a"

subtitles:
  - ""
  - ""
  - ""
  - ""
  - ""
  - ""
  - ""
  - ""
  - ""

phases:
  scene_1:
    duration: 8
    description: "Linear functions showcase"
    elements:
      linear_positive:
        type: xy_graph
        position: [-200, -50]
        size: 200
        function: "x"
        x_range: [-3, 3]
        y_range: [-3, 3]
        color: "#e74c3c"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = x"
        resolution: 100
      
      linear_slope:
        type: xy_graph
        position: [200, -50]
        size: 200
        function: "2*x"
        x_range: [-3, 3]
        y_range: [-6, 6]
        color: "#3498db"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = 2x"
        resolution: 100
      
      linear_negative:
        type: xy_graph
        position: [-200, 130]
        size: 200
        function: "-x"
        x_range: [-3, 3]
        y_range: [-3, 3]
        color: "#2ecc71"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = -x"
        resolution: 100
      
      linear_offset:
        type: xy_graph
        position: [200, 130]
        size: 200
        function: "x + 2"
        x_range: [-3, 3]
        y_range: [-1, 5]
        color: "#f39c12"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = x + 2"
        resolution: 100
      
      title_text:
        type: text
        text: "Linear Functions"
        position: [0, -220]
        size: 18
        color: "#ffffff"
        glow: true
        font: "Arial"
  
  scene_2:
    duration: 8
    description: "Polynomial functions - quadratic and cubic"
    elements:
      quadratic_positive:
        type: xy_graph
        position: [-200, -50]
        size: 200
        function: "x^2"
        x_range: [-3, 3]
        y_range: [0, 9]
        color: "#9b59b6"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = x²"
        resolution: 150
      
      quadratic_negative:
        type: xy_graph
        position: [200, -50]
        size: 200
        function: "-x^2"
        x_range: [-3, 3]
        y_range: [-9, 0]
        color: "#1abc9c"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = -x²"
        resolution: 150
      
      cubic:
        type: xy_graph
        position: [-200, 130]
        size: 200
        function: "x^3"
        x_range: [-2, 2]
        y_range: [-8, 8]
        color: "#e67e22"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = x³"
        resolution: 150
      
      quartic:
        type: xy_graph
        position: [200, 130]
        size: 200
        function: "x^4"
        x_range: [-2, 2]
        y_range: [0, 16]
        color: "#34495e"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = x⁴"
        resolution: 150
      
      title_text:
        type: text
        text: "Polynomial Functions"
        position: [0, -220]
        size: 18
        color: "#ffffff"
        glow: true
        font: "Arial"
  
  scene_3:
    duration: 8
    description: "Trigonometric functions"
    elements:
      sine:
        type: xy_graph
        position: [-200, -50]
        size: 200
        function: "sin(x)"
        x_range: [-6.28, 6.28]
        y_range: [-1.5, 1.5]
        color: "#e74c3c"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = sin(x)"
        resolution: 200
      
      cosine:
        type: xy_graph
        position: [200, -50]
        size: 200
        function: "cos(x)"
        x_range: [-6.28, 6.28]
        y_range: [-1.5, 1.5]
        color: "#3498db"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = cos(x)"
        resolution: 200
      
      tangent:
        type: xy_graph
        position: [-200, 130]
        size: 200
        function: "tan(x)"
        x_range: [-1.5, 1.5]
        y_range: [-3, 3]
        color: "#2ecc71"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = tan(x)"
        resolution: 150
      
      sine_scaled:
        type: xy_graph
        position: [200, 130]
        size: 200
        function: "2*sin(x)"
        x_range: [-6.28, 6.28]
        y_range: [-2.5, 2.5]
        color: "#f39c12"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = 2sin(x)"
        resolution: 200
      
      title_text:
        type: text
        text: "Trigonometric Functions"
        position: [0, -220]
        size: 18
        color: "#ffffff"
        glow: true
        font: "Arial"
  
  scene_4:
    duration: 8
    description: "Exponential and logarithmic functions"
    elements:
      exponential:
        type: xy_graph
        position: [-200, -50]
        size: 200
        function: "exp(x)"
        x_range: [-2, 2]
        y_range: [0, 8]
        color: "#9b59b6"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = eˣ"
        resolution: 150
      
      exponential_2:
        type: xy_graph
        position: [200, -50]
        size: 200
        function: "2^x"
        x_range: [-3, 3]
        y_range: [0, 8]
        color: "#1abc9c"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = 2ˣ"
        resolution: 150
      
      logarithm:
        type: xy_graph
        position: [-200, 130]
        size: 200
        function: "log(x)"
        x_range: [0.1, 10]
        y_range: [-3, 3]
        color: "#e67e22"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = ln(x)"
        resolution: 150
      
      exponential_decay:
        type: xy_graph
        position: [200, 130]
        size: 200
        function: "exp(-x)"
        x_range: [-2, 2]
        y_range: [0, 8]
        color: "#34495e"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = e⁻ˣ"
        resolution: 150
      
      title_text:
        type: text
        text: "Exponential & Logarithmic Functions"
        position: [0, -220]
        size: 18
        color: "#ffffff"
        glow: true
        font: "Arial"
  
  scene_5:
    duration: 8
    description: "Special functions - absolute, square root, rational"
    elements:
      absolute:
        type: xy_graph
        position: [-200, -50]
        size: 200
        function: "abs(x)"
        x_range: [-3, 3]
        y_range: [0, 3]
        color: "#e74c3c"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = |x|"
        resolution: 150
      
      square_root:
        type: xy_graph
        position: [200, -50]
        size: 200
        function: "sqrt(x)"
        x_range: [0, 9]
        y_range: [0, 3]
        color: "#3498db"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = √x"
        resolution: 150
      
      reciprocal:
        type: xy_graph
        position: [-200, 130]
        size: 200
        function: "1/x"
        x_range: [-3, 3]
        y_range: [-3, 3]
        color: "#2ecc71"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = 1/x"
        resolution: 150
      
      absolute_quadratic:
        type: xy_graph
        position: [200, 130]
        size: 200
        function: "abs(x^2 - 4)"
        x_range: [-3, 3]
        y_range: [0, 6]
        color: "#f39c12"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = |x² - 4|"
        resolution: 150
      
      title_text:
        type: text
        text: "Special Functions"
        position: [0, -220]
        size: 18
        color: "#ffffff"
        glow: true
        font: "Arial"
  
  scene_6:
    duration: 8
    description: "Data points representation and custom combinations"
    elements:
      data_points_only:
        type: xy_graph
        position: [-200, -50]
        size: 200
        data_points: [[0, 0], [1, 1], [2, 4], [3, 9], [-1, 1], [-2, 4], [-3, 9]]
        x_range: [-4, 4]
        y_range: [0, 10]
        color: "#9b59b6"
        line_width: 2
        show_grid: true
        show_axes: true
        show_labels: true
        show_points: true
        smooth_curve: true
        animate_draw: true
        title: "Data Points: y = x²"
        resolution: 100
      
      mixed_points:
        type: xy_graph
        position: [200, -50]
        size: 200
        data_points: [[-3, -2], [-2, 0], [-1, 1], [0, 0], [1, -1], [2, 0], [3, 2]]
        x_range: [-4, 4]
        y_range: [-3, 3]
        color: "#1abc9c"
        line_width: 2
        show_grid: true
        show_axes: true
        show_labels: true
        show_points: true
        smooth_curve: true
        animate_draw: true
        title: "Custom Data Points"
        resolution: 100
      
      combined_function:
        type: xy_graph
        position: [-200, 130]
        size: 200
        function: "sin(x) * x"
        x_range: [-6.28, 6.28]
        y_range: [-7, 7]
        color: "#e67e22"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = x·sin(x)"
        resolution: 200
      
      polynomial_complex:
        type: xy_graph
        position: [200, 130]
        size: 200
        function: "x^3 - 3*x"
        x_range: [-2.5, 2.5]
        y_range: [-5, 5]
        color: "#34495e"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = x³ - 3x"
        resolution: 150
      
      title_text:
        type: text
        text: "Data Points & Complex Functions"
        position: [0, -220]
        size: 18
        color: "#ffffff"
        glow: true
        font: "Arial"
  
  scene_7:
    duration: 8
    description: "Hyperbolic and inverse trigonometric functions"
    elements:
      hyperbolic_sinh:
        type: xy_graph
        position: [-260, -80]
        size: 170
        function: "sinh(x)"
        x_range: [-2, 2]
        y_range: [-4, 4]
        color: "#e74c3c"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = sinh(x)"
        resolution: 150
      
      hyperbolic_cosh:
        type: xy_graph
        position: [0, -80]
        size: 170
        function: "cosh(x)"
        x_range: [-2, 2]
        y_range: [0, 4]
        color: "#3498db"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = cosh(x)"
        resolution: 150
      
      hyperbolic_tanh:
        type: xy_graph
        position: [260, -80]
        size: 170
        function: "tanh(x)"
        x_range: [-3, 3]
        y_range: [-1.5, 1.5]
        color: "#2ecc71"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = tanh(x)"
        resolution: 150
      
      inverse_sin:
        type: xy_graph
        position: [-260, 120]
        size: 170
        function: "asin(x)"
        x_range: [-1, 1]
        y_range: [-2, 2]
        color: "#f39c12"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = arcsin(x)"
        resolution: 150
      
      inverse_cos:
        type: xy_graph
        position: [0, 120]
        size: 170
        function: "acos(x)"
        x_range: [-1, 1]
        y_range: [0, 3.5]
        color: "#9b59b6"
        line_width: 3
        show_grid: true
        show_axes: true
        show_labels: true
        smooth_curve: true
        animate_draw: true
        title: "f(x) = arccos(x)"
        resolution: 150
      
      inverse_tan:
        type: xy_graph
        position: [260, 120]
        size: 170
