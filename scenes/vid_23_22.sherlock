concept: "Neural Network Forward Pass"
emoji: "⚡"
total_duration: 38
background: "#000000"

subtitles:
  - ""

phases:

  scene_01_forward_pass:
    duration: 38
    description: "Neural network wakes, signal flows from inputs through 4 hidden nodes to output, weights reveal as packets travel, o0 fires amber cinematic"
    elements:

      scene_tag:
        type: primitive
        shape: text[text:"① FORWARD PASS" fontSize:15 fill:#ffffff/0.3 at:(-6.5,5.5)] -> fadeIn(0.6s, 0.2s)

      layer_label_input:
        type: primitive
        shape: text[text:"Input Layer  L₀" fontSize:18 fill:#ffffff/0.35 at:(-5.8,4.8)] -> fadeIn(0.6s, 0.4s)

      layer_label_hidden:
        type: primitive
        shape: text[text:"Hidden Layer  L₁" fontSize:18 fill:#ffffff/0.35 at:(0.0,4.8)] -> fadeIn(0.6s, 0.7s)

      layer_label_output:
        type: primitive
        shape: text[text:"Output Layer  L₂" fontSize:18 fill:#ffffff/0.35 at:(5.8,4.8)] -> fadeIn(0.6s, 1.0s)

      i0_box:
