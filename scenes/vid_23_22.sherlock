        shape: rectangle[w:1.5 h:1.5 fill:#6bffb8/0.10 stroke:#6bffb8/0.30 strokeWidth:1.5 at:(-6.0,1.8)] -> fadeIn(0.8s, 1.2s) ~> rectangle[w:1.5 h:1.5 fill:#6bffb8/0.40 stroke:#6bffb8/0.80 strokeWidth:2.0 at:(-6.0,1.8)] (0.5s, ease.out, 4.0s) ~> rectangle[w:1.5 h:1.5 fill:#6bffb8/0.18 stroke:#6bffb8/0.40 strokeWidth:1.5 at:(-6.0,1.8)] (0.6s, ease.inOut, 4.6s)

