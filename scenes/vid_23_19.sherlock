  scene_08_network_tcp:
    duration: 38
    description: "Packet routing is local greedy decisions repeated; TCP guarantees delivery while UDP fires and forgets."
    elements:

      scene_tag:
        type: primitive
        shape: text[text:"⑧ NETWORK PACKETS & TCP/UDP" fontSize:15 fill:#ffffff/0.3 at:(-5.2,4.85)] -> fadeIn(0.6s, 0.2s)

