        type: morph
        shape: text[text:"FACT 14 — DATABASE INDEX" fontSize:22 fill:#ffffff/0 at:(3.8,3.8) ] ~> text[text:"FACT 14 — DATABASE INDEX" fontSize:22 fill:#ffffff/0.8 at:(3.8,3.8)] (0.5s, ease.out, 10.3s)

