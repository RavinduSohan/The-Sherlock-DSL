concept: "Computer Science Fundamentals — Algorithms, Networks, APIs"
emoji: "🌐"
total_duration: 114
background: "#2F343A"

subtitles:
  - ""

phases:

  scene_07_bigo_index:
    duration: 38
    description: "O(n²) explodes beyond the canvas at scale; a database index collapses full scan to a single jump."
    elements:

      scene_tag:
        type: primitive
        shape: text[text:"⑦ BIG O & DATABASE INDEX" fontSize:15 fill:#ffffff/0.3 at:(-5.2,4.85)] -> fadeIn(0.6s, 0.2s)

      divider:
        type: primitive
        shape: line[from:(0,3.2) to:(0,-3.2) stroke:#ffffff/0.15 strokeWidth:1] -> fadeIn(0.3s, 0s)

      left_title:
        type: primitive
        shape: text[text:"FACT 13 — BIG O" fontSize:22 fill:#ffffff/0.8 at:(-3.2,3.8)] -> fadeIn(0.5s, 0.5s)

      axis_x:
        type: morph
        shape: line[from:(-5.8,-0.5) to:(-5.8,-0.5) stroke:#ffffff/0.2 strokeWidth:1] ~> line[from:(-5.8,-0.5) to:(-0.6,-0.5) stroke:#ffffff/0.2 strokeWidth:1] (0.8s, ease.out, 0.3s)

      axis_y:
        type: morph
        shape: line[from:(-5.8,-0.5) to:(-5.8,-0.5) stroke:#ffffff/0.2 strokeWidth:1] ~> line[from:(-5.8,-0.5) to:(-5.8,2.2) stroke:#ffffff/0.2 strokeWidth:1] (0.6s, ease.out, 0.3s)

      curve_linear:
        type: primitive
        shape: functionGraph[fn:"0.18*x" xStart:0 xEnd:6 segments:60 stroke:#4fc3f7/0.6 strokeWidth:2 at:(-5.8,-0.5)]

      curve_quad:
        type: morph
        shape: functionGraph[fn:"0.03*x*x" xStart:0 xEnd:6 segments:80 stroke:#c77aff/0.5 strokeWidth:2 at:(-5.8,-0.5)] -> fadeIn(0.5s, 0.4s) ~> functionGraph[fn:"0.03*x*x" xStart:0 xEnd:6 segments:80 stroke:#ff6b9d/0.7 strokeWidth:2.5 at:(-5.8,-0.5)] (0.5s, ease.out, 5.2s)

      lbl_on:
        type: primitive
        shape: text[text:"O(n)" fontSize:13 fill:#4fc3f7/0.85 at:(-2.0,1.5)] -> fadeIn(0.5s, 0.5s)

      lbl_on2:
        type: primitive
        shape: text[text:"O(n²)" fontSize:13 fill:#c77aff/0.85 at:(-1.0,2.0)] -> fadeIn(0.5s, 0.6s)

      small_n_label:
        type: morph
        shape: text[text:"n=10: similar" fontSize:13 fill:#ffffff/0 at:(-3.8,1.0)] ~> text[text:"n=10: similar" fontSize:13 fill:#ffffff/0.7 at:(-3.8,1.0)] (0.4s, ease.out, 0.8s) ~> text[text:"n=10: similar" fontSize:13 fill:#ffffff/0 at:(-3.8,1.0)] (0.4s, ease.out, 2.8s)

      bar_on_base:
        type: morph
        shape: rectangle[w:0.35 h:0.05 fill:#4fc3f7/0 stroke:#4fc3f7/0 strokeWidth:1 at:(-4.8,-0.35)] ~> rectangle[w:0.35 h:0.28 fill:#4fc3f7/0.45 stroke:#4fc3f7/0.7 strokeWidth:1.5 at:(-4.8,-0.36)] (0.5s, ease.out, 2.8s) ~> rectangle[w:0.35 h:0.28 fill:#4fc3f7/0.45 stroke:#4fc3f7/0.7 strokeWidth:1.5 at:(-4.8,-0.36)] (0.4s, ease.out, 5.5s)

      bar_on2_base:
        type: morph
        shape: rectangle[w:0.35 h:0.05 fill:#c77aff/0 stroke:#c77aff/0 strokeWidth:1 at:(-4.2,-0.35)] ~> rectangle[w:0.35 h:0.28 fill:#c77aff/0.35 stroke:#c77aff/0.6 strokeWidth:1.5 at:(-4.2,-0.36)] (0.5s, ease.out, 3.0s) ~> rectangle[w:0.35 h:2.4 fill:#ff6b9d/0.45 stroke:#ff6b9d/0.75 strokeWidth:2 at:(-4.2,0.7)] (0.6s, ease.out, 5.3s)

      overshoot_lbl:
        type: morph
