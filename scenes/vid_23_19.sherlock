      edge_r1_r2:
        type: morph
        shape: line[from:(-4.22,1.27) to:(-4.22,1.27) stroke:#4fc3f7/0 strokeWidth:1] ~> line[from:(-4.22,1.27) to:(-3.68,0.53) stroke:#4fc3f7/0.7 strokeWidth:2] (0.4s, ease.out, 1.5s)

