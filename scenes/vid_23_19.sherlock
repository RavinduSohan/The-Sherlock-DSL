        type: morph
        shape: circle[r:0.38 fill:#6bffb8/0.35 stroke:#6bffb8/0.6 strokeWidth:1.5 at:(-1.2,0.8)] -> fadeIn(0.5s, 0.3s) ~> circle[r:0.38 fill:#6bffb8/0.65 stroke:#6bffb8/0.9 strokeWidth:2 at:(-1.2,0.8)] (0.4s, ease.out, 4.5s)

      lbl_dst:
